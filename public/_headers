/
  Cache-Control: no-cache, must-revalidate

/*.html
  Cache-Control: no-cache, must-revalidate

/*.css
  Cache-Control: no-cache, must-revalidate

/*.js
  Cache-Control: no-cache, must-revalidate

/portal/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: private, no-store

/api/aura
  Cache-Control: no-store, max-age=0
  X-Content-Type-Options: nosniff
